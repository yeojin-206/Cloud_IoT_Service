# 서버 설정
PORT=3000
HOST=0.0.0.0

# MQTT 브로커 설정
# - 학교/회사 네트워크에서 공용 브로커가 막힌 경우 MQTT_ENABLED=false 로 끄면
#   서버는 HTTP 경로(Axios)만으로 정상 동작한다.
# - Raspberry Pi에 mosquitto 를 직접 설치한 경우 MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_ENABLED=true
MQTT_BROKER_URL=mqtt://test.mosquitto.org:1883
MQTT_TOPIC_SENSOR=healthcare/sensor
MQTT_TOPIC_FITBIT=healthcare/fitbit
MQTT_CLIENT_ID=rpi-edge-server

# 사용자 설정 (Fitbit 시뮬레이터 기본값)
USER_ID=user-001

# 수집 주기 (ms)
SENSOR_INTERVAL_MS=3000
FITBIT_INTERVAL_MS=5000

# Fitbit 실기기 OAuth2 (시뮬레이터만 쓸 거면 비워둬도 됨)
# 1) https://dev.fitbit.com/apps 에서 Personal 앱 등록
# 2) 발급받은 Client ID / Secret 을 아래 입력
# 3) FITBIT_ENABLED=true 로 바꾸고 서버 실행 후
#    http://localhost:3000/auth/fitbit 접속 → Fitbit 로그인 → 권한 승인
FITBIT_ENABLED=false
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REDIRECT_URI=http://localhost:3000/auth/fitbit/callback
# Fitbit Web API Rate Limit: 150 req/hr → 60000ms 권장
FITBIT_POLL_INTERVAL_MS=60000
